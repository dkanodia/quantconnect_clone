# ============================================================
# Database
# ============================================================

# SQLite — local dev default.
# Leave DATABASE_URL unset (or comment it out) to use SQLite.
# DATABASE_URL=sqlite:///./backtester.db

# PostgreSQL — Railway / Render production.
# Railway sets this automatically when you add the PostgreSQL plugin.
DATABASE_URL=postgresql://user:password@host:5432/backtester

# ============================================================
# Auth — first-boot admin seeding
# ============================================================

# Set these before running the seed command to create the first admin account.
ADMIN_EMAIL=admin@yourteam.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=changeme123

# ============================================================
# Optional — email notifications (Phase 15)
# ============================================================

# Uncomment and fill in to enable outbound email alerts.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# NOTIFY_FROM_EMAIL=noreply@yourteam.com
